# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# E*TRADE API credentials (from developer.etrade.com)
ETRADE_CONSUMER_KEY=your_consumer_key_here
ETRADE_CONSUMER_SECRET=your_consumer_secret_here

# Environment: sandbox | production
ETRADE_ENV=sandbox

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Per-phase model routing for report generation (all optional — defaults shown)
# SCAN_MODEL=claude-fable-5        # Phase 1 candidate identification
# RESEARCH_MODEL=claude-opus-4-8   # Phase 2 tool call loop
# REPORT_MODEL=claude-fable-5      # Final report generation and ranking

# SQLite database path (default: ./data/trading.db)
# DB_PATH=./data/trading.db

# Monitor / alert thresholds (all optional — defaults shown)
# VOLUME_SPIKE_FACTOR=1.5   # volume must exceed N × 5-period average to trigger entry
# PROFIT_TARGET_PCT=2.0     # exit when price rises this % above the entry_low
# STOP_LOSS_PCT=1.0         # exit when price falls this % below the entry_low

# Web dashboard port (default: 5000)
# WEB_PORT=5000
